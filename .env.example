# =============================================================
# DentalERP Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# ── Database (MySQL) ──────────────────────────────────────────
# Replace 'root' and 'password' with your MySQL credentials
DATABASE_URL="mysql://root:password@localhost:3306/dental_erp"

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=""

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"

# ── Application ───────────────────────────────────────────────
NODE_ENV="development"

# ── Payment Gateway Encryption (REQUIRED) ─────────────────────
# AES-256-GCM needs a 64-character hex string (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ── Cron Jobs Security (REQUIRED) ────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CRON_SECRET=""

# ── AI (NVIDIA NIM) — Optional ────────────────────────────────
# Required only for AI features (treatment advisor, smart scheduler, etc.)
# Default provider: NVIDIA NIM / Build NVIDIA
# Default model: minimaxai/minimax-m2.7
NVIDIA_API_KEY=""
# Optional backward-compatible alias if you still use legacy config names
OPENROUTER_API_KEY=""
# Optional override for local/self-hosted OpenAI-compatible providers
# Example for LM Studio: AI_BASE_URL="http://localhost:1234/v1"
AI_BASE_URL=""
AI_API_KEY=""
AI_MODEL="minimaxai/minimax-m2.7"
# Optional cost/performance split. Ignored when AI_MODEL is set.
AI_FAST_MODEL=""
AI_REASONING_MODEL=""

# ── Email (SMTP) — Optional ──────────────────────────────────
# Required for email notifications, password reset, etc.
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASSWORD=""

# ── SMS Gateway — Optional ───────────────────────────────────
# Required for SMS appointment reminders
SMS_API_KEY=""
SMS_SENDER_ID="DENTAL"

# ── Video Consultation — Optional ─────────────────────────────
# Jitsi Meet (free, no API key needed)
JITSI_DOMAIN="meet.jit.si"
# Or use Daily.co (requires API key):
# DAILY_API_KEY=""
# DAILY_DOMAIN="your-domain.daily.co"
